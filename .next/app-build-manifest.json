      "static/chunks/app/(dashboard)/pricing/page.js"
    ],
    "/(dashboard)/discover/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/discover/page.js"
    ],
    "/(dashboard)/groups/[groupId]/page": [
